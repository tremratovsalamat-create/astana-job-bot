# ─────────────────────────────────────────────────
#  Astana Jobs Bot — Environment Variables
# ─────────────────────────────────────────────────
#  1. Переименуй этот файл в .env
#  2. Вставь свой токен от @BotFather
# ─────────────────────────────────────────────────

# Токен твоего бота (получи у @BotFather в Telegram)
BOT_TOKEN=your_bot_token_here

# Твой Telegram user_id (опционально, для /stats команды)
ADMIN_ID=0

# Путь к базе данных
DB_PATH=jobs_bot.db
